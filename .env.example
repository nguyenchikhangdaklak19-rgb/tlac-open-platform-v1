# Copy to .env.local and fill in real values. Never commit secrets.

# Postgres (or compatible) connection string for the CMS/auth data store.
DATABASE_URL=

# Comma-separated list of emails that should be granted admin access on
# sign-in/seed (mechanism decided by Tech Lead — see spec/tlac-open-platform-v1.md).
ADMIN_EMAILS=

# Webhook URL (Slack/email relay) that support-request submissions are
# pushed to.
SUPPORT_WEBHOOK_URL=

# API key for Resend (or equivalent) transactional email provider, used for
# auth email (OTP/magic link) and support notifications.
RESEND_API_KEY=

# Secret used to sign/encrypt user sessions.
SESSION_SECRET=
